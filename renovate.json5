{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'local>SlashNephy/renovate-config',
  ],
  packageRules: [
    {
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        'ghcr.io/slashnephy/**',
        'ghcr.io/starrybluesky/**',
      ],
      minimumReleaseAge: null,
      versioning: 'loose',
    },
    {
      groupName: 'immich',
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        'ghcr.io/immich-app/**',
      ],
    },
    // OCI イメージで参照されるチャートで pinDigest を無効化する
    // https://github.com/renovatebot/renovate/discussions/38038
    {
      matchManagers: [
        'kustomize',
      ],
      matchDepNames: [
        'influxdb',
        'mariadb',
        'postgresql',
        'redis',
        'valkey',
        'cert-manager',
        'n8n',
        'gha-runner-scale-set-controller',
        'gha-runner-scale-set',
        'openclaw-operator',
        'librechat',
        'grafana',
        'loki',
      ],
      pinDigest: {
        enabled: false,
      },
    },
  ],
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        'k8s/apps/openclaw/resources/instance.yaml',
      ],
      matchStrings: [
        'repository:\\s*(?<depName>[^\\s]+)\\s*\\n\\s*tag:\\s*(?<currentValue>[^\\s]+)\\s*\\n\\s*digest:\\s*(?<currentDigest>sha256:[a-f0-9]+)',
      ],
      datasourceTemplate: 'docker',
    },
    {
      customType: 'regex',
      managerFilePatterns: [
        '.github/workflows/deploy-headlessx.yml',
      ],
      matchStrings: [
        '# renovate: datasource=github-tags depName=(?<depName>[^\\s]+)\\n\\s*ref:\\s*(?<currentValue>[^\\s]+)',
      ],
      datasourceTemplate: 'github-tags',
    },
  ],
  rebaseWhen: 'conflicted',
}
